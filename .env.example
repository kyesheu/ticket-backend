# ==========================================
# Ticket Backend 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会上传
# ==========================================

SERVER_PORT=8080

# 数据库连接（必填）
DB_URL=jdbc:mysql://localhost:3306/ticket_backend?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=false&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=change_me

# Redis 连接
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# Token 密钥（必填，生产环境请更换为随机字符串）
TOKEN_SECRET=change_me_to_a_long_random_string
TOKEN_EXPIRE_TIME=30

# Druid 监控面板
DRUID_STAT_USERNAME=admin
DRUID_STAT_PASSWORD=change_me

# 文件上传路径
UPLOAD_PATH=./uploadPath

# 功能开关
SWAGGER_ENABLED=true
DEVTOOLS_RESTART_ENABLED=true

# 工单检索
TICKET_SEARCH_ENABLED=false
TICKET_SEARCH_URIS=http://localhost:9200
TICKET_SEARCH_CURSOR_SECRET=change_me_to_a_long_random_string

# AI 智能辅助
TICKET_AI_ENABLED=true
TICKET_AI_BASE_URL=http://127.0.0.1:8090
TICKET_AI_SERVICE_TOKEN=change_me_to_a_long_random_string
TICKET_AI_CONNECT_TIMEOUT=2s
TICKET_AI_READ_TIMEOUT=10s
TICKET_AI_MAX_RESPONSE_BYTES=1048576
TICKET_AI_ELASTICSEARCH_URL=http://127.0.0.1:9200
TICKET_AI_KNOWLEDGE_INDEX=ticket-knowledge-v1
TICKET_AI_TICKET_HISTORY_INDEX=ticket-history-v1
TICKET_AI_SMOKE_MODE=false
TICKET_AI_EMBEDDING_API_KEY=replace_with_dashscope_api_key
TICKET_AI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TICKET_AI_EMBEDDING_MODEL=text-embedding-v4
TICKET_AI_LLM_API_KEY=replace_with_dashscope_api_key
TICKET_AI_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TICKET_AI_LLM_MODEL=qwen-plus

# 日志级别
LOG_LEVEL_RUOYI=debug
LOG_LEVEL_TICKET=debug
LOG_LEVEL_SPRING=warn
